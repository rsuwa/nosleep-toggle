#!/usr/bin/env bash
set -euo pipefail

if [[ -n "${XDG_RUNTIME_DIR:-}" ]]; then
  state_dir="$XDG_RUNTIME_DIR/nosleep"
else
  state_dir="/tmp/nosleep-$(id -u)"
fi

pid_file="$state_dir/inhibit.pid"
start_file="$state_dir/inhibit.start"
lock_file="$state_dir/lock"

what="handle-lid-switch:sleep:idle"
who_persistent="nosleep:persistent"
who_running="nosleep:running"
who_legacy="nosleep"
why="keep CLI agents running while lid is closed"
current_uid="$(id -u)"

prepare_state_dir() {
  if [[ -L "$state_dir" ]]; then
    printf 'refusing symlink state directory: %s\n' "$state_dir" >&2
    exit 1
  fi

  mkdir -p "$state_dir"

  if [[ ! -d "$state_dir" || ! -O "$state_dir" ]]; then
    printf 'unsafe state directory: %s\n' "$state_dir" >&2
    exit 1
  fi

  chmod 700 "$state_dir"
}

prepare_state_dir

usage() {
  cat <<'EOF'
Usage:
  nosleep on              Block sleep, idle sleep, and lid-close suspend.
  nosleep off             Stop the persistent blocker.
  nosleep toggle          Toggle the persistent blocker.
  nosleep status          Print "on", "running", or "off".
  nosleep shell           Start an inhibited shell. Type "exit" to release.
  nosleep run <command>   Run a command while sleep is blocked.
  nosleep <command> [...] Shortcut for "nosleep run <command> [...]".

Examples:
  nosleep on
  nosleep off
  nosleep status
  nosleep long-command --option
  nosleep run long-command --option
  nosleep run bash -lc 'long-command --option'
EOF
}

read_pid() {
  [[ -r "$pid_file" ]] || return 1

  local pid
  pid="$(<"$pid_file")"
  [[ "$pid" =~ ^[0-9]+$ ]] || return 1
  printf '%s\n' "$pid"
}

is_persistent_running() {
  local pid
  pid="$(read_pid)" || return 1
  process_matches_persistent "$pid" || return 1
  process_matches_recorded_start "$pid"
}

process_matches_persistent() {
  local pid="$1"
  local argv

  [[ -r "/proc/$pid/cmdline" ]] || return 1
  argv="$(tr '\0' '\n' 2>/dev/null <"/proc/$pid/cmdline")" || return 1

  grep -E '(^|/)systemd-inhibit$' <<<"$argv" >/dev/null || return 1
  grep -Fx -- "--who=$who_persistent" <<<"$argv" >/dev/null \
    || grep -Fx -- "--who=$who_legacy" <<<"$argv" >/dev/null
}

process_start_time() {
  local pid="$1"
  local stat fields

  [[ -r "/proc/$pid/stat" ]] || return 1
  IFS= read -r stat 2>/dev/null <"/proc/$pid/stat" || return 1
  fields="${stat##*) }"
  # shellcheck disable=SC2086 # Split /proc stat fields into positional parameters.
  set -- $fields
  [[ "${20:-}" =~ ^[0-9]+$ ]] || return 1
  printf '%s\n' "${20}"
}

process_matches_recorded_start() {
  local pid="$1"
  local recorded current

  [[ -r "$start_file" ]] || return 0
  recorded="$(<"$start_file")"
  [[ "$recorded" =~ ^[0-9]+$ ]] || return 1
  current="$(process_start_time "$pid")" || return 1
  [[ "$recorded" == "$current" ]]
}

process_has_recorded_identity() {
  local pid="$1"
  [[ -r "$start_file" ]] || return 1
  process_matches_persistent "$pid" || return 1
  process_matches_recorded_start "$pid"
}

is_temporary_running() {
  local inhibitors
  inhibitors="$(list_inhibitors 2>/dev/null)" || return 1
  inhibitors_include_temporary "$inhibitors"
}

list_inhibitors() {
  systemd-inhibit --list --no-pager --no-legend
}

inhibitor_pid_from_list() {
  local inhibitors="$1"
  local expected_who="$2"
  local allow_legacy="${3:-0}"
  local expected_pid="${4:-}"
  local line inhibitor_who inhibitor_uid inhibitor_pid inhibitor_comm inhibitor_what inhibitor_mode

  while IFS= read -r line; do
    [[ -n "$line" ]] || continue

    read -r inhibitor_who inhibitor_uid _inhibitor_user inhibitor_pid inhibitor_comm inhibitor_what _ <<<"$line"
    inhibitor_mode="${line##* }"

    if [[ "$inhibitor_who" != "$expected_who" ]]; then
      [[ "$allow_legacy" -eq 1 && "$inhibitor_who" == "$who_legacy" ]] || continue
    fi
    [[ "$inhibitor_uid" == "$current_uid" ]] || continue
    [[ "$inhibitor_pid" =~ ^[0-9]+$ ]] || continue
    [[ -z "$expected_pid" || "$inhibitor_pid" == "$expected_pid" ]] || continue
    [[ "$inhibitor_comm" == "systemd-inhibit" ]] || continue
    [[ "$inhibitor_mode" == "block" ]] || continue
    [[ ":$inhibitor_what:" == *":handle-lid-switch:"* ]] || continue
    [[ ":$inhibitor_what:" == *":sleep:"* ]] || continue
    [[ ":$inhibitor_what:" == *":idle:"* ]] || continue

    printf '%s\n' "$inhibitor_pid"
    return 0
  done <<<"$inhibitors"

  return 1
}

persistent_inhibitor_pid_from_list() {
  inhibitor_pid_from_list "$1" "$who_persistent" 1 "${2:-}"
}

temporary_inhibitor_pid_from_list() {
  inhibitor_pid_from_list "$1" "$who_running"
}

find_persistent_inhibitor_pid() {
  local expected_pid="${1:-}"
  local inhibitors
  inhibitors="$(list_inhibitors 2>/dev/null)" || return 1
  persistent_inhibitor_pid_from_list "$inhibitors" "$expected_pid"
}

wait_for_persistent_inhibitor() {
  local pid="$1"

  for _ in {1..20}; do
    if find_persistent_inhibitor_pid "$pid" >/dev/null; then
      return 0
    fi
    sleep 0.1
  done

  return 1
}

inhibitors_include_persistent() {
  local inhibitors="$1"
  persistent_inhibitor_pid_from_list "$inhibitors" >/dev/null
}

inhibitors_include_temporary() {
  local inhibitors="$1"
  temporary_inhibitor_pid_from_list "$inhibitors" >/dev/null
}

cleanup_stale_pid() {
  if ! is_persistent_running; then
    rm -f "$pid_file" "$start_file"
  fi
}

write_state_value() {
  local path="$1"
  local value="$2"
  local tmp

  tmp="$(mktemp "${path}.tmp.XXXXXX")" || return 1
  if ! printf '%s\n' "$value" >"$tmp"; then
    rm -f "$tmp"
    return 1
  fi

  mv -f "$tmp" "$path"
}

stop_started_blocker() {
  local pid="$1"

  [[ -n "$pid" ]] || return 0
  kill -TERM -- "-$pid" 2>/dev/null || kill -TERM "$pid" 2>/dev/null || true

  for _ in {1..20}; do
    if ! kill -0 "$pid" 2>/dev/null; then
      return 0
    fi
    sleep 0.1
  done

  kill -KILL -- "-$pid" 2>/dev/null || kill -KILL "$pid" 2>/dev/null || true
}

start_blocker() {
  local pid start_time cleanup_new_blocker

  cleanup_stale_pid
  if is_persistent_running; then
    printf 'on\n'
    return 0
  fi

  setsid systemd-inhibit \
    --what="$what" \
    --mode=block \
    --who="$who_persistent" \
    --why="$why" \
    -- \
    sleep infinity >/dev/null 2>&1 9>&- &

  pid="$!"
  cleanup_new_blocker=1
  trap 'if [[ "${cleanup_new_blocker:-0}" -eq 1 ]]; then stop_started_blocker "$pid"; rm -f "$pid_file" "$start_file" "$pid_file".tmp.* "$start_file".tmp.*; fi' RETURN

  start_time="$(process_start_time "$pid")" || {
    printf 'failed to inspect systemd-inhibit process\n' >&2
    return 1
  }
  write_state_value "$pid_file" "$pid" || {
    printf 'failed to write state file: %s\n' "$pid_file" >&2
    return 1
  }
  write_state_value "$start_file" "$start_time" || {
    printf 'failed to write state file: %s\n' "$start_file" >&2
    return 1
  }
  if ! is_persistent_running || ! wait_for_persistent_inhibitor "$pid"; then
    rm -f "$pid_file" "$start_file"
    printf 'failed to start systemd-inhibit\n' >&2
    return 1
  fi

  cleanup_new_blocker=0
  trap - RETURN
  printf 'on\n'
}

stop_blocker() {
  local pid kill_group
  pid="$(read_pid 2>/dev/null || true)"
  kill_group=0

  if [[ -n "$pid" ]] && is_persistent_running; then
    if process_has_recorded_identity "$pid"; then
      kill_group=1
    fi

    if [[ "$kill_group" -eq 1 ]]; then
      kill -TERM -- "-$pid" 2>/dev/null || kill -TERM "$pid" 2>/dev/null || true
    else
      kill -TERM "$pid" 2>/dev/null || true
    fi

    for _ in {1..20}; do
      if ! is_persistent_running; then
        break
      fi
      sleep 0.1
    done

    if is_persistent_running; then
      if [[ "$kill_group" -eq 1 ]]; then
        kill -KILL -- "-$pid" 2>/dev/null || kill -KILL "$pid" 2>/dev/null || true
      else
        kill -KILL "$pid" 2>/dev/null || true
      fi
    fi
  else
    pid="$(find_persistent_inhibitor_pid || true)"

    if [[ -n "$pid" ]]; then
      kill -TERM "$pid" 2>/dev/null || true

      for _ in {1..20}; do
        if ! find_persistent_inhibitor_pid >/dev/null; then
          break
        fi
        sleep 0.1
      done

      if find_persistent_inhibitor_pid >/dev/null; then
        kill -KILL "$pid" 2>/dev/null || true
      fi
    fi
  fi

  if find_persistent_inhibitor_pid >/dev/null; then
    printf 'failed to stop persistent systemd-inhibit\n' >&2
    return 1
  fi

  rm -f "$pid_file" "$start_file"
  status
}

status() {
  local inhibitors

  cleanup_stale_pid

  if ! inhibitors="$(list_inhibitors 2>/dev/null)"; then
    if is_persistent_running; then
      printf 'on\n'
      return 0
    fi

    printf 'failed to query systemd inhibitors\n' >&2
    return 1
  fi

  if is_persistent_running; then
    printf 'on\n'
  elif inhibitors_include_persistent "$inhibitors"; then
    printf 'on\n'
  elif inhibitors_include_temporary "$inhibitors"; then
    printf 'running\n'
  else
    printf 'off\n'
  fi
}

run_shell() {
  printf 'nosleep active: lid-close suspend and idle sleep are blocked. Type "exit" to release.\n' >&2
  exec systemd-inhibit --what="$what" --mode=block --who="$who_running" --why="$why" -- "${SHELL:-/bin/bash}"
}

run_command() {
  if [[ $# -eq 0 ]]; then
    usage >&2
    exit 2
  fi

  exec systemd-inhibit --what="$what" --mode=block --who="$who_running" --why="$why" -- "$@"
}

command="${1:-}"

case "$command" in
  -h|--help|help)
    usage
    ;;
  --status)
    exec systemd-inhibit --list --no-pager
    ;;
  "")
    run_shell
    ;;
  shell)
    run_shell
    ;;
  on)
    exec 9>"$lock_file"
    flock -x 9
    start_blocker
    ;;
  off)
    exec 9>"$lock_file"
    flock -x 9
    stop_blocker
    ;;
  toggle)
    exec 9>"$lock_file"
    flock -x 9
    if is_persistent_running; then
      stop_blocker
    else
      start_blocker
    fi
    ;;
  status)
    exec 9>"$lock_file"
    flock -x 9
    status
    ;;
  run)
    shift
    run_command "$@"
    ;;
  --)
    shift
    run_command "$@"
    ;;
  *)
    run_command "$@"
    ;;
esac
