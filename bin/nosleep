#!/usr/bin/env bash
set -euo pipefail

if [[ -n "${XDG_RUNTIME_DIR:-}" ]]; then
  state_dir="$XDG_RUNTIME_DIR/nosleep"
else
  state_dir="/tmp/nosleep-$(id -u)"
fi

pid_file="$state_dir/inhibit.pid"
start_file="$state_dir/inhibit.start"
lock_file="$state_dir/lock"

what="handle-lid-switch:sleep:idle"
who_persistent="nosleep:persistent"
who_running="nosleep:running"
who_legacy="nosleep"
why="keep CLI agents running while lid is closed"

prepare_state_dir() {
  if [[ -L "$state_dir" ]]; then
    printf 'refusing symlink state directory: %s\n' "$state_dir" >&2
    exit 1
  fi

  mkdir -p "$state_dir"

  if [[ ! -d "$state_dir" || ! -O "$state_dir" ]]; then
    printf 'unsafe state directory: %s\n' "$state_dir" >&2
    exit 1
  fi

  chmod 700 "$state_dir"
}

prepare_state_dir

usage() {
  cat <<'EOF'
Usage:
  nosleep on              Block sleep, idle sleep, and lid-close suspend.
  nosleep off             Stop the persistent blocker.
  nosleep toggle          Toggle the persistent blocker.
  nosleep status          Print "on", "running", or "off".
  nosleep shell           Start an inhibited shell. Type "exit" to release.
  nosleep run <command>   Run a command while sleep is blocked.
  nosleep <command> [...] Shortcut for "nosleep run <command> [...]".

Examples:
  nosleep on
  nosleep off
  nosleep status
  nosleep long-command --option
  nosleep run long-command --option
  nosleep run bash -lc 'long-command --option'
EOF
}

read_pid() {
  [[ -r "$pid_file" ]] || return 1

  local pid
  pid="$(<"$pid_file")"
  [[ "$pid" =~ ^[0-9]+$ ]] || return 1
  printf '%s\n' "$pid"
}

is_persistent_running() {
  local pid
  pid="$(read_pid)" || return 1
  process_matches_persistent "$pid" || return 1
  process_matches_recorded_start "$pid"
}

process_matches_persistent() {
  local pid="$1"
  local argv

  [[ -r "/proc/$pid/cmdline" ]] || return 1
  argv="$(tr '\0' '\n' 2>/dev/null <"/proc/$pid/cmdline")" || return 1

  grep -E '(^|/)systemd-inhibit$' <<<"$argv" >/dev/null || return 1
  grep -Fx -- "--who=$who_persistent" <<<"$argv" >/dev/null \
    || grep -Fx -- "--who=$who_legacy" <<<"$argv" >/dev/null
}

process_start_time() {
  local pid="$1"
  local stat fields

  [[ -r "/proc/$pid/stat" ]] || return 1
  IFS= read -r stat 2>/dev/null <"/proc/$pid/stat" || return 1
  fields="${stat##*) }"
  set -- $fields
  [[ "${20:-}" =~ ^[0-9]+$ ]] || return 1
  printf '%s\n' "${20}"
}

process_matches_recorded_start() {
  local pid="$1"
  local recorded current

  [[ -r "$start_file" ]] || return 0
  recorded="$(<"$start_file")"
  [[ "$recorded" =~ ^[0-9]+$ ]] || return 1
  current="$(process_start_time "$pid")" || return 1
  [[ "$recorded" == "$current" ]]
}

process_has_recorded_identity() {
  local pid="$1"
  [[ -r "$start_file" ]] || return 1
  process_matches_persistent "$pid" || return 1
  process_matches_recorded_start "$pid"
}

is_temporary_running() {
  local inhibitors
  inhibitors="$(list_inhibitors 2>/dev/null)" || return 1
  inhibitors_include_temporary "$inhibitors"
}

list_inhibitors() {
  systemd-inhibit --list --no-pager --no-legend
}

inhibitors_include_persistent() {
  local inhibitors="$1"
  grep -F "$who_persistent" <<<"$inhibitors" >/dev/null \
    || grep -E "^${who_legacy}[[:space:]]" <<<"$inhibitors" >/dev/null
}

inhibitors_include_temporary() {
  local inhibitors="$1"
  grep -F "$who_running" <<<"$inhibitors" >/dev/null
}

cleanup_stale_pid() {
  if ! is_persistent_running; then
    rm -f "$pid_file" "$start_file"
  fi
}

start_blocker() {
  cleanup_stale_pid
  if is_persistent_running; then
    printf 'on\n'
    return 0
  fi

  setsid systemd-inhibit \
    --what="$what" \
    --mode=block \
    --who="$who_persistent" \
    --why="$why" \
    sleep infinity >/dev/null 2>&1 9>&- &

  local pid start_time
  pid="$!"
  printf '%s\n' "$pid" >"$pid_file"
  if start_time="$(process_start_time "$pid" 2>/dev/null)"; then
    printf '%s\n' "$start_time" >"$start_file"
  fi
  sleep 0.2

  if ! is_persistent_running; then
    rm -f "$pid_file" "$start_file"
    printf 'failed to start systemd-inhibit\n' >&2
    return 1
  fi

  printf 'on\n'
}

stop_blocker() {
  local pid kill_group
  pid="$(read_pid 2>/dev/null || true)"
  kill_group=0

  if [[ -n "$pid" ]] && is_persistent_running; then
    if process_has_recorded_identity "$pid"; then
      kill_group=1
    fi

    if [[ "$kill_group" -eq 1 ]]; then
      kill -TERM -- "-$pid" 2>/dev/null || kill -TERM "$pid" 2>/dev/null || true
    else
      kill -TERM "$pid" 2>/dev/null || true
    fi

    for _ in {1..20}; do
      if ! is_persistent_running; then
        break
      fi
      sleep 0.1
    done

    if is_persistent_running; then
      if [[ "$kill_group" -eq 1 ]]; then
        kill -KILL -- "-$pid" 2>/dev/null || kill -KILL "$pid" 2>/dev/null || true
      else
        kill -KILL "$pid" 2>/dev/null || true
      fi
    fi
  fi

  rm -f "$pid_file" "$start_file"
  status
}

status() {
  local inhibitors

  cleanup_stale_pid

  if ! inhibitors="$(list_inhibitors 2>/dev/null)"; then
    if is_persistent_running; then
      printf 'on\n'
      return 0
    fi

    printf 'failed to query systemd inhibitors\n' >&2
    return 1
  fi

  if is_persistent_running; then
    printf 'on\n'
  elif inhibitors_include_persistent "$inhibitors"; then
    printf 'on\n'
  elif inhibitors_include_temporary "$inhibitors"; then
    printf 'running\n'
  else
    printf 'off\n'
  fi
}

run_shell() {
  printf 'nosleep active: lid-close suspend and idle sleep are blocked. Type "exit" to release.\n' >&2
  exec systemd-inhibit --what="$what" --mode=block --who="$who_running" --why="$why" "${SHELL:-/bin/bash}"
}

run_command() {
  if [[ $# -eq 0 ]]; then
    usage >&2
    exit 2
  fi

  exec systemd-inhibit --what="$what" --mode=block --who="$who_running" --why="$why" "$@"
}

command="${1:-}"

case "$command" in
  -h|--help|help)
    usage
    ;;
  --status)
    exec systemd-inhibit --list --no-pager
    ;;
  "")
    run_shell
    ;;
  shell)
    run_shell
    ;;
  on)
    exec 9>"$lock_file"
    flock -x 9
    start_blocker
    ;;
  off)
    exec 9>"$lock_file"
    flock -x 9
    stop_blocker
    ;;
  toggle)
    exec 9>"$lock_file"
    flock -x 9
    if is_persistent_running; then
      stop_blocker
    else
      start_blocker
    fi
    ;;
  status)
    exec 9>"$lock_file"
    flock -s 9
    status
    ;;
  run)
    shift
    run_command "$@"
    ;;
  --)
    shift
    run_command "$@"
    ;;
  *)
    run_command "$@"
    ;;
esac
