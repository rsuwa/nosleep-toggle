#!/bin/bash
set -euo pipefail

user_path="$PATH"
trusted_path="${NOSLEEP_TRUSTED_PATH:-/usr/sbin:/usr/bin:/sbin:/bin}"

resolve_required_command() {
  local command_name="$1"
  local command_path

  command_path="$(PATH="$trusted_path" command -v "$command_name")" || {
    printf 'Missing required command: %s\n' "$command_name" >&2
    exit 1
  }

  case "$command_path" in
    /*)
      printf '%s\n' "$command_path"
      ;;
    *)
      printf 'Missing required command: %s\n' "$command_name" >&2
      exit 1
      ;;
  esac
}

id_cmd="$(resolve_required_command id)"
systemd_inhibit_cmd="$(resolve_required_command systemd-inhibit)"
setsid_cmd="$(resolve_required_command setsid)"
flock_cmd="$(resolve_required_command flock)"
mkdir_cmd="$(resolve_required_command mkdir)"
chmod_cmd="$(resolve_required_command chmod)"
mktemp_cmd="$(resolve_required_command mktemp)"
mv_cmd="$(resolve_required_command mv)"
rm_cmd="$(resolve_required_command rm)"
sleep_cmd="$(resolve_required_command sleep)"

if [[ -n "${XDG_RUNTIME_DIR:-}" ]]; then
  state_dir="$XDG_RUNTIME_DIR/nosleep"
else
  state_dir="/tmp/nosleep-$("$id_cmd" -u)"
fi

pid_file="$state_dir/inhibit.pid"
start_file="$state_dir/inhibit.start"
boot_file="$state_dir/inhibit.boot"

what="handle-lid-switch:sleep:idle"
who_persistent="nosleep:persistent"
who_running="nosleep:running"
who_legacy="nosleep"
why="keep CLI agents running while lid is closed"
current_uid="$("$id_cmd" -u)"

prepare_state_dir() {
  if [[ -e "$state_dir" ]]; then
    if [[ -L "$state_dir" || ! -d "$state_dir" || ! -O "$state_dir" ]]; then
      printf 'unsafe state directory: %s\n' "$state_dir" >&2
      exit 1
    fi
  else
    "$mkdir_cmd" -- "$state_dir" || {
      printf 'failed to create state directory: %s\n' "$state_dir" >&2
      exit 1
    }
  fi

  if [[ -L "$state_dir" || ! -d "$state_dir" || ! -O "$state_dir" ]]; then
    printf 'unsafe state directory: %s\n' "$state_dir" >&2
    exit 1
  fi

  "$chmod_cmd" 700 -- "$state_dir"
}

prepare_state_dir

usage() {
  printf '%s\n' \
    'Usage:' \
    '  nosleep on              Block sleep, idle sleep, and lid-close suspend.' \
    '  nosleep off             Stop the persistent blocker.' \
    '  nosleep toggle          Toggle the persistent blocker.' \
    '  nosleep status          Print "on", "running", or "off".' \
    '  nosleep shell           Start an inhibited shell. Type "exit" to release.' \
    '  nosleep run <command>   Run a command while sleep is blocked.' \
    '  nosleep <command> [...] Shortcut for "nosleep run <command> [...]".' \
    '  nosleep --raw-status    Print the raw global systemd-inhibit list.' \
    '' \
    'Examples:' \
    '  nosleep on' \
    '  nosleep off' \
    '  nosleep status' \
    '  nosleep long-command --option' \
    '  nosleep run long-command --option' \
    "  nosleep run bash -lc 'long-command --option'"
}

read_pid() {
  [[ -r "$pid_file" ]] || return 1

  local pid
  pid="$(<"$pid_file")"
  [[ "$pid" =~ ^[0-9]+$ ]] || return 1
  printf '%s\n' "$pid"
}

is_persistent_running() {
  local pid
  pid="$(read_pid)" || return 1
  process_matches_persistent "$pid" || return 1
  process_matches_recorded_start "$pid" || return 1
  process_matches_recorded_boot
}

process_uid_matches_current() {
  local pid="$1"
  local key real_uid

  [[ -r "/proc/$pid/status" ]] || return 1
  while read -r key real_uid _; do
    if [[ "$key" == "Uid:" ]]; then
      [[ "$real_uid" == "$current_uid" ]]
      return
    fi
  done <"/proc/$pid/status"

  return 1
}

process_matches_inhibitor_invocation() {
  local pid="$1"
  local expected_who="$2"
  local allow_legacy="${3:-0}"
  local arg index found_who found_what found_mode

  process_uid_matches_current "$pid" || return 1
  [[ -r "/proc/$pid/cmdline" ]] || return 1

  index=0
  found_who=0
  found_what=0
  found_mode=0
  while IFS= read -r -d '' arg; do
    if [[ "$index" -eq 0 ]]; then
      [[ "${arg##*/}" == "systemd-inhibit" ]] || return 1
    fi

    case "$arg" in
      "--who=$expected_who")
        found_who=1
        ;;
      "--who=$who_legacy")
        if [[ "$allow_legacy" -eq 1 ]]; then
          found_who=1
        fi
        ;;
      "--what=$what")
        found_what=1
        ;;
      "--mode=block")
        found_mode=1
        ;;
    esac

    ((index += 1))
  done <"/proc/$pid/cmdline"

  [[ "$index" -gt 0 ]] || return 1
  [[ "$found_who" -eq 1 ]] || return 1
  [[ "$found_what" -eq 1 ]] || return 1
  [[ "$found_mode" -eq 1 ]]
}

process_matches_persistent() {
  local pid="$1"
  process_matches_inhibitor_invocation "$pid" "$who_persistent" 1
}

process_start_time() {
  local pid="$1"
  local stat fields

  [[ -r "/proc/$pid/stat" ]] || return 1
  IFS= read -r stat 2>/dev/null <"/proc/$pid/stat" || return 1
  fields="${stat##*) }"
  # shellcheck disable=SC2086 # Split /proc stat fields into positional parameters.
  set -- $fields
  [[ "${20:-}" =~ ^[0-9]+$ ]] || return 1
  printf '%s\n' "${20}"
}

current_boot_id() {
  local boot_id

  [[ -r /proc/sys/kernel/random/boot_id ]] || return 1
  IFS= read -r boot_id </proc/sys/kernel/random/boot_id || return 1
  [[ "$boot_id" =~ ^[0-9a-fA-F-]+$ ]] || return 1
  printf '%s\n' "$boot_id"
}

process_matches_recorded_start() {
  local pid="$1"
  local recorded current

  [[ -r "$start_file" ]] || return 1
  recorded="$(<"$start_file")"
  [[ "$recorded" =~ ^[0-9]+$ ]] || return 1
  current="$(process_start_time "$pid")" || return 1
  [[ "$recorded" == "$current" ]]
}

process_matches_recorded_boot() {
  local recorded current

  [[ -r "$boot_file" ]] || return 1
  recorded="$(<"$boot_file")"
  [[ "$recorded" =~ ^[0-9a-fA-F-]+$ ]] || return 1
  current="$(current_boot_id)" || return 1
  [[ "$recorded" == "$current" ]]
}

process_has_recorded_identity() {
  local pid="$1"
  [[ -r "$start_file" ]] || return 1
  process_matches_persistent "$pid" || return 1
  process_matches_recorded_start "$pid" || return 1
  process_matches_recorded_boot
}

recorded_persistent_inhibitor_in_list() {
  local inhibitors="$1"
  local pid

  pid="$(read_pid)" || return 1
  process_matches_recorded_start "$pid" || return 1
  process_matches_recorded_boot || return 1
  persistent_inhibitor_pid_from_list "$inhibitors" "$pid" >/dev/null
}

list_inhibitors() {
  "$systemd_inhibit_cmd" --list --no-pager --no-legend
}

inhibitor_pids_from_list() {
  local inhibitors="$1"
  local expected_who="$2"
  local allow_legacy="${3:-0}"
  local expected_pid="${4:-}"
  local line inhibitor_who inhibitor_uid inhibitor_pid inhibitor_comm inhibitor_what inhibitor_mode
  local found=1

  while IFS= read -r line; do
    [[ -n "$line" ]] || continue

    read -r inhibitor_who inhibitor_uid _inhibitor_user inhibitor_pid inhibitor_comm inhibitor_what _ <<<"$line"
    inhibitor_mode="${line##* }"

    if [[ "$inhibitor_who" != "$expected_who" ]]; then
      [[ "$allow_legacy" -eq 1 && "$inhibitor_who" == "$who_legacy" ]] || continue
    fi
    [[ "$inhibitor_uid" == "$current_uid" ]] || continue
    [[ "$inhibitor_pid" =~ ^[0-9]+$ ]] || continue
    [[ -z "$expected_pid" || "$inhibitor_pid" == "$expected_pid" ]] || continue
    [[ "$inhibitor_comm" == "systemd-inhibit" ]] || continue
    [[ "$inhibitor_mode" == "block" ]] || continue
    [[ ":$inhibitor_what:" == *":handle-lid-switch:"* ]] || continue
    [[ ":$inhibitor_what:" == *":sleep:"* ]] || continue
    [[ ":$inhibitor_what:" == *":idle:"* ]] || continue
    process_matches_inhibitor_invocation "$inhibitor_pid" "$expected_who" "$allow_legacy" || continue

    printf '%s\n' "$inhibitor_pid"
    found=0
  done <<<"$inhibitors"

  return "$found"
}

inhibitor_pid_from_list() {
  local pid

  while IFS= read -r pid; do
    printf '%s\n' "$pid"
    return 0
  done < <(inhibitor_pids_from_list "$@")

  return 1
}

persistent_inhibitor_pid_from_list() {
  inhibitor_pid_from_list "$1" "$who_persistent" 1 "${2:-}"
}

persistent_inhibitor_pids_from_list() {
  inhibitor_pids_from_list "$1" "$who_persistent" 1 "${2:-}"
}

temporary_inhibitor_pid_from_list() {
  inhibitor_pid_from_list "$1" "$who_running"
}

find_persistent_inhibitor_pid() {
  local expected_pid="${1:-}"
  local inhibitors
  inhibitors="$(list_inhibitors 2>/dev/null)" || return 1
  persistent_inhibitor_pid_from_list "$inhibitors" "$expected_pid"
}

find_persistent_inhibitor_pids() {
  local inhibitors
  inhibitors="$(list_inhibitors 2>/dev/null)" || return 1
  persistent_inhibitor_pids_from_list "$inhibitors"
}

wait_for_persistent_inhibitor() {
  local pid="$1"

  for _ in {1..20}; do
    if find_persistent_inhibitor_pid "$pid" >/dev/null; then
      return 0
    fi
    "$sleep_cmd" 0.1
  done

  return 1
}

inhibitors_include_persistent() {
  local inhibitors="$1"
  persistent_inhibitor_pid_from_list "$inhibitors" >/dev/null
}

inhibitors_include_temporary() {
  local inhibitors="$1"
  temporary_inhibitor_pid_from_list "$inhibitors" >/dev/null
}

cleanup_stale_pid() {
  if ! is_persistent_running; then
    "$rm_cmd" -f "$pid_file" "$start_file" "$boot_file"
  fi
}

cleanup_stale_pid_from_list() {
  local inhibitors="$1"

  read_pid >/dev/null 2>&1 || return 0
  if ! recorded_persistent_inhibitor_in_list "$inhibitors"; then
    "$rm_cmd" -f "$pid_file" "$start_file" "$boot_file"
  fi
}

persistent_active() {
  local inhibitors

  if inhibitors="$(list_inhibitors 2>/dev/null)"; then
    cleanup_stale_pid_from_list "$inhibitors"
    recorded_persistent_inhibitor_in_list "$inhibitors" || inhibitors_include_persistent "$inhibitors"
  else
    is_persistent_running
  fi
}

write_state_value() {
  local path="$1"
  local value="$2"
  local tmp

  tmp="$("$mktemp_cmd" "${path}.tmp.XXXXXX")" || return 1
  if ! printf '%s\n' "$value" >"$tmp"; then
    "$rm_cmd" -f "$tmp"
    return 1
  fi

  "$mv_cmd" -f "$tmp" "$path"
}

stop_started_blocker() {
  local pid="$1"

  [[ -n "$pid" ]] || return 0
  kill -TERM -- "-$pid" 2>/dev/null || kill -TERM "$pid" 2>/dev/null || true

  for _ in {1..20}; do
    if ! kill -0 "$pid" 2>/dev/null; then
      return 0
    fi
    "$sleep_cmd" 0.1
  done

  kill -KILL -- "-$pid" 2>/dev/null || kill -KILL "$pid" 2>/dev/null || true
}

stop_listed_persistent_blockers() {
  local pid pids

  mapfile -t pids < <(find_persistent_inhibitor_pids || true)
  [[ "${#pids[@]}" -gt 0 ]] || return 0

  for pid in "${pids[@]}"; do
    kill -TERM "$pid" 2>/dev/null || true
  done

  for _ in {1..20}; do
    if ! find_persistent_inhibitor_pid >/dev/null; then
      return 0
    fi
    "$sleep_cmd" 0.1
  done

  if find_persistent_inhibitor_pid >/dev/null; then
    for pid in "${pids[@]}"; do
      kill -KILL "$pid" 2>/dev/null || true
    done
  fi
}

cleanup_started_blocker() {
  local pid="$1"

  [[ "${cleanup_new_blocker:-0}" -eq 1 ]] || return 0
  cleanup_new_blocker=0
  stop_started_blocker "$pid"
  "$rm_cmd" -f \
    "$pid_file" "$start_file" "$boot_file" \
    "$pid_file".tmp.* "$start_file".tmp.* "$boot_file".tmp.*
}

start_blocker() {
  local pid start_time boot_id cleanup_new_blocker

  cleanup_stale_pid
  if persistent_active; then
    printf 'on\n'
    return 0
  fi

  (
    cd / || exit 1
    exec "$setsid_cmd" "$systemd_inhibit_cmd" \
      --what="$what" \
      --mode=block \
      --who="$who_persistent" \
      --why="$why" \
      -- \
      "$sleep_cmd" infinity
  ) </dev/null >/dev/null 2>&1 9>&- &

  pid="$!"
  cleanup_new_blocker=1
  trap 'cleanup_started_blocker "$pid"' RETURN EXIT
  trap 'cleanup_started_blocker "$pid"; exit 129' HUP
  trap 'cleanup_started_blocker "$pid"; exit 130' INT
  trap 'cleanup_started_blocker "$pid"; exit 143' TERM

  start_time="$(process_start_time "$pid")" || {
    printf 'failed to inspect systemd-inhibit process\n' >&2
    return 1
  }
  boot_id="$(current_boot_id)" || {
    printf 'failed to inspect boot id\n' >&2
    return 1
  }
  write_state_value "$pid_file" "$pid" || {
    printf 'failed to write state file: %s\n' "$pid_file" >&2
    return 1
  }
  write_state_value "$start_file" "$start_time" || {
    printf 'failed to write state file: %s\n' "$start_file" >&2
    return 1
  }
  write_state_value "$boot_file" "$boot_id" || {
    printf 'failed to write state file: %s\n' "$boot_file" >&2
    return 1
  }
  if ! is_persistent_running || ! wait_for_persistent_inhibitor "$pid"; then
    "$rm_cmd" -f "$pid_file" "$start_file" "$boot_file"
    printf 'failed to start systemd-inhibit\n' >&2
    return 1
  fi

  cleanup_new_blocker=0
  trap - RETURN EXIT HUP INT TERM
  printf 'on\n'
}

stop_blocker() {
  local pid
  pid="$(read_pid 2>/dev/null || true)"

  if [[ -n "$pid" ]] && process_has_recorded_identity "$pid"; then
    kill -TERM -- "-$pid" 2>/dev/null || kill -TERM "$pid" 2>/dev/null || true

    for _ in {1..20}; do
      if ! is_persistent_running; then
        break
      fi
      "$sleep_cmd" 0.1
    done

    if is_persistent_running; then
      kill -KILL -- "-$pid" 2>/dev/null || kill -KILL "$pid" 2>/dev/null || true
    fi
  fi

  stop_listed_persistent_blockers

  if find_persistent_inhibitor_pid >/dev/null; then
    printf 'failed to stop persistent systemd-inhibit\n' >&2
    return 1
  fi

  "$rm_cmd" -f "$pid_file" "$start_file" "$boot_file"
  status
}

status() {
  local inhibitors

  cleanup_stale_pid

  if ! inhibitors="$(list_inhibitors 2>/dev/null)"; then
    if is_persistent_running; then
      printf 'on\n'
      return 0
    fi

    printf 'failed to query systemd inhibitors\n' >&2
    return 1
  fi

  cleanup_stale_pid_from_list "$inhibitors"

  if recorded_persistent_inhibitor_in_list "$inhibitors"; then
    printf 'on\n'
  elif inhibitors_include_persistent "$inhibitors"; then
    printf 'on\n'
  elif inhibitors_include_temporary "$inhibitors"; then
    printf 'running\n'
  else
    printf 'off\n'
  fi
}

run_shell() {
  printf 'nosleep active: lid-close suspend and idle sleep are blocked. Type "exit" to release.\n' >&2
  PATH="$user_path" exec "$systemd_inhibit_cmd" --what="$what" --mode=block --who="$who_running" --why="$why" -- "${SHELL:-/bin/bash}"
}

run_command() {
  if [[ $# -eq 0 ]]; then
    usage >&2
    exit 2
  fi

  PATH="$user_path" exec "$systemd_inhibit_cmd" --what="$what" --mode=block --who="$who_running" --why="$why" -- "$@"
}

command="${1:-}"

case "$command" in
  -h|--help|help)
    usage
    ;;
  --status|--raw-status)
    exec "$systemd_inhibit_cmd" --list --no-pager
    ;;
  "")
    run_shell
    ;;
  shell)
    run_shell
    ;;
  on)
    exec 9<"$state_dir"
    "$flock_cmd" -x 9
    start_blocker
    ;;
  off)
    exec 9<"$state_dir"
    "$flock_cmd" -x 9
    stop_blocker
    ;;
  toggle)
    exec 9<"$state_dir"
    "$flock_cmd" -x 9
    if persistent_active; then
      stop_blocker
    else
      start_blocker
    fi
    ;;
  status)
    exec 9<"$state_dir"
    "$flock_cmd" -x 9
    status
    ;;
  run)
    shift
    run_command "$@"
    ;;
  --)
    shift
    run_command "$@"
    ;;
  *)
    run_command "$@"
    ;;
esac
