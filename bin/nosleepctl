#!/usr/bin/env bash
set -euo pipefail

runtime_base="${XDG_RUNTIME_DIR:-/tmp}"
state_dir="$runtime_base/nosleepctl"
pid_file="$state_dir/inhibit.pid"
lock_file="$state_dir/lock"

what="handle-lid-switch:sleep:idle"
who="nosleep-panel"
why="keep CLI agents running while lid is closed"

mkdir -p "$state_dir"

usage() {
  cat <<'EOF'
Usage:
  nosleepctl on       Block sleep, idle sleep, and lid-close suspend.
  nosleepctl off      Stop the blocker started by nosleepctl.
  nosleepctl toggle   Toggle on/off.
  nosleepctl status   Print "on" or "off".
EOF
}

read_pid() {
  [[ -r "$pid_file" ]] || return 1

  local pid
  pid="$(<"$pid_file")"
  [[ "$pid" =~ ^[0-9]+$ ]] || return 1
  printf '%s\n' "$pid"
}

is_running() {
  local pid cmdline
  pid="$(read_pid)" || return 1
  [[ -r "/proc/$pid/cmdline" ]] || return 1

  cmdline="$(tr '\0' ' ' <"/proc/$pid/cmdline")"
  [[ "$cmdline" == *"systemd-inhibit"* && "$cmdline" == *"$who"* ]]
}

cleanup_stale_pid() {
  if ! is_running; then
    rm -f "$pid_file"
  fi
}

start_blocker() {
  cleanup_stale_pid
  if is_running; then
    printf 'on\n'
    return 0
  fi

  setsid systemd-inhibit \
    --what="$what" \
    --mode=block \
    --who="$who" \
    --why="$why" \
    sleep infinity >/dev/null 2>&1 9>&- &

  printf '%s\n' "$!" >"$pid_file"
  sleep 0.2

  if ! is_running; then
    rm -f "$pid_file"
    printf 'failed to start systemd-inhibit\n' >&2
    return 1
  fi

  printf 'on\n'
}

stop_blocker() {
  local pid
  pid="$(read_pid 2>/dev/null || true)"

  if [[ -n "$pid" ]] && is_running; then
    kill -TERM -- "-$pid" 2>/dev/null || kill -TERM "$pid" 2>/dev/null || true

    for _ in {1..20}; do
      if ! is_running; then
        break
      fi
      sleep 0.1
    done

    if is_running; then
      kill -KILL -- "-$pid" 2>/dev/null || kill -KILL "$pid" 2>/dev/null || true
    fi
  fi

  rm -f "$pid_file"
  printf 'off\n'
}

status() {
  cleanup_stale_pid
  if is_running; then
    printf 'on\n'
  else
    printf 'off\n'
  fi
}

command="${1:-}"

case "$command" in
  -h|--help|help)
    usage
    ;;
  on)
    exec 9>"$lock_file"
    flock -x 9
    start_blocker
    ;;
  off)
    exec 9>"$lock_file"
    flock -x 9
    stop_blocker
    ;;
  toggle)
    exec 9>"$lock_file"
    flock -x 9
    if is_running; then
      stop_blocker
    else
      start_blocker
    fi
    ;;
  status)
    exec 9>"$lock_file"
    flock -s 9
    status
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
